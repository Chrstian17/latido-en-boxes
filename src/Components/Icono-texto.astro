---
const {titulo} = Astro.props
const {explicacion} = Astro.props
const {icono} = Astro.props
---

<div class="ayuda">
    <img src={icono} alt="">
    <h3 class="">{titulo}</h3>
    <p class="">{explicacion}</p>

</div>


<style>

.ayuda {

    display: flex;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
    text-align: center;



img {
margin-bottom: 1em;
  height: 70px;
}
p {
margin-top: 0rem;
  max-width: 24ch;
  text-align: center;
}

}




</style>