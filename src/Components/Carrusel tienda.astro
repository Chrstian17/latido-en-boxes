---
import Card from "../Components/Card.astro";
---

<div class="swiper swiper-tienda">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper">
    <!-- Slides -->

    <div class="swiper-slide">
      <Card
        title="Collar Martingale"
        description="Disponemos de tres tallas para que puedas seleccionar el collar que mejor se adapte a las características únicas de tu mascota. "
        price="16'99 €"
        img="/assets/collar-martingale.webp"
      />
    </div>
      <div class="swiper-slide">
      <Card
        title="Collar de piel"
        description="Collar para perro, Galgos, fabricado artesanalmente en piel auténtica, con detalle de Galgos bordado."
        price="24'90 €"
        img="/assets/collar-piel.webp"
      />
    </div>
     <div class="swiper-slide">
      <Card
        title="Crema para almohadillas"
        description="Nuestro protector patas perro nutre intensamente las almohadillas secas, agrietadas o irritadas. "
        price="10'99 €"
        img="/assets/crema.webp"
      />
    </div>
      <div class="swiper-slide">
      <Card
        title="Collar para Galgos Aalborg"
        description="El discreto collar de piel de vacuno de alta calidad es ideal debido a su forma especial para todos los galgos."
        price="21'10 €"
        img="/assets/collar-aalborg.webp"
      />
    </div>
      <div class="swiper-slide">
      <Card
        title="Arnés antiescape"
        description="Arnés para perros diseñado para el máximo confort, de nailon resistente y robusto, forma ergonómica con suave acolchado, muy cómodo para el animal"
        price="46'10 €"
        img="/assets/arnes.webp"
      />
    </div>
 
          <div class="swiper-slide">
      <Card
        title="Ultra Squeaker Ball"
        description="¡Chuckit! Crea juguetes interactivos y atractivos para perros que forjan vínculos duraderos entre las personas y sus mascotas."
        price="5'49 €"
        img="/assets/pelota.webp"
      />
    </div>
 
  </div>
  <div class="swiper-nav">
    <button class="swiper-arrow button button-light is-prev"
      ><i class="ph-bold ph-caret-left"></i></button
    >
    <button class="swiper-arrow button button-light is-next"
      ><i class="ph-bold ph-caret-right"></i></button
    >
  </div>
</div>

<style>
  .swiper-tienda .swiper-arrow {
    padding: .8em;
    border: none;
    display: flex;
    cursor: pointer;
  }

  .swiper-tienda .swiper-nav {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    justify-content: start;
    padding-bottom: 1rem;
    i {
      font-size: 1.75rem;
    }
  }

  .swiper {
    width: 100%;

    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .swiper-tienda .swiper-slide {
    align-content: center;
    width: 100%;
    height: auto;
  }
  .swiper img {
    width: 100%;
  }



</style>
